post_install() {
    update-desktop-database -q 2>/dev/null || true
    gtk-update-icon-cache -f /usr/share/icons/hicolor 2>/dev/null || true
}

post_upgrade() {
    post_install
}

post_remove() {
    update-desktop-database -q 2>/dev/null || true
    gtk-update-icon-cache -f /usr/share/icons/hicolor 2>/dev/null || true
}
